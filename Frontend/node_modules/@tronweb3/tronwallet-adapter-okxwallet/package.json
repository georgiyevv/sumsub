{
  "name": "@tronweb3/tronwallet-adapter-okxwallet",
  "version": "1.0.8",
  "description": "Wallet adapter for Okx Wallet extension and Okx Wallet app.",
  "keywords": [
    "TRON",
    "TronWeb",
    "Okx Wallet"
  ],
  "author": "tronweb3",
  "repository": {
    "type": "git",
    "url": "https://github.com/tronweb3/tronwallet-adapter"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=16",
    "pnpm": ">=7"
  },
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    "require": "./lib/cjs/index.js",
    "import": "./lib/esm/index.js",
    "types": "./lib/types/index.d.ts"
  },
  "files": [
    "lib",
    "src",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tronweb3/tronwallet-adapter-tronlink": "^1.1.14",
    "@tronweb3/tronwallet-abstract-adapter": "^1.1.12"
  },
  "devDependencies": {
    "@testing-library/dom": "8.20.1",
    "shx": "0.3.4",
    "vitest": "3.2.4"
  },
  "scripts": {
    "clean": "shx mkdir -p lib && shx rm -rf lib",
    "package": "shx echo '{ \"type\": \"commonjs\" }' > lib/cjs/package.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:umd": "node ../../../scripts/build-umd.js"
  }
}